# ===============================================
# Local .env (developer machine) ownership guide
# ===============================================
# Copy this file to `.env` and fill in local values.
#
# Put secrets here for local development (for example TIINGO_API_TOKEN).
# Do not duplicate secrets directly in docker-compose service definitions.
# Docker should reference secret values from this `.env` via ${VAR}.
#
# Put developer/runtime values here that are shared across local Python runs
# and Docker variable substitution.

# Shared database connection used by local Python runs.
# Docker service-internal database wiring belongs in docker-compose.yml.
DATABASE_URL=postgresql+psycopg://stocklake:stocklake@localhost:5432/stocklake

# Optional token for live Tiingo backfills. Leave empty for non-network tests.
TIINGO_API_TOKEN=

# Tiingo API base URL override (defaults to production Tiingo API).
TIINGO_BASE_URL=https://api.tiingo.com

# Runtime environment label used by services.
APP_ENV=dev

# Integration test database URL (defaults to DATABASE_URL in current tests).
INTEGRATION_DATABASE_URL=postgresql+psycopg://stocklake:stocklake@localhost:5432/stocklake

# Optional override for mcp-stocklake to locate datalake package source.
# Leave blank when using this monorepo's default layout.
DATALAKE_SERVICE_PATH=
